# Copy this file to .env and fill in your local values.
# NEVER commit a populated .env file to version control.

# ── Spring Profile ──────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ── Database ────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=DesiRestroRoot@1234
MYSQL_DATABASE=desi_restro_db
MYSQL_USER=desi_restro
MYSQL_PASSWORD=DesiRestro@1234

# ── JWT ─────────────────────────────────────────────────
# Generate a secure secret: openssl rand -base64 64
JWT_SECRET=change-this-to-a-strong-base64-encoded-secret

# ── CORS / Frontend Origins ─────────────────────────────
APP_ALLOWED_ORIGINS=http://localhost:3000

# ── App Port ─────────────────────────────────────────────
PORT=8080
